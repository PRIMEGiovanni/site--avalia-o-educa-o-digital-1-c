// Função para renderizar o carrossel de testemunhos
function renderTestimonials() {
    const carousel = document.getElementById('testimonials-carousel');
    let currentIndex = 0;

    const displayTestimonial = () => {
        carousel.innerHTML = `
            <div class="testimonial-card">
                <p>"${testimonials[currentIndex].text}"</p>
                <p>- ${testimonials[currentIndex].name}</p>
            </div>
            <button onclick="previousTestimonial()">Anterior</button>
            <button onclick="nextTestimonial()">Próximo</button>
        `;
    };

    const nextTestimonial = () => {
        currentIndex = (currentIndex + 1) % testimonials.length;
        displayTestimonial();
    };

    const previousTestimonial = () => {
        currentIndex = (currentIndex - 1 + testimonials.length) % testimonials.length;
        displayTestimonial();
    };

    displayTestimonial();
}

renderTestimonials();
